DISCORD_TOKEN=your_discord_bot_token
DISCORD_INVITE_URL=https://discord.gg/39Wje3aQ
DISCORD_GUILD_ID=1441229464548671633
DISCORD_EPISODE_CHANNEL_ID=1441229465597251738
# Optional. If omitted, these default to DISCORD_EPISODE_CHANNEL_ID.
DISCORD_DISCUSSION_CHANNEL_ID=
DISCORD_MEME_CHANNEL_ID=
DISCORD_GROWTH_CHANNEL_ID=

# Optional AI provider settings. If omitted, bot uses built-in fallback templates.
# Option A: OpenAI
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4.1-mini
# AI_BASE_URL=
#
# Option B: OpenRouter free tier (recommended if you want a free API key)
AI_API_KEY=
AI_MODEL=nvidia/nemotron-3-super-120b-a12b:free
MEME_AI_MODEL=arcee-ai/trinity-large-preview:free
AI_BASE_URL=https://openrouter.ai/api/v1
# Optional extra meme sources (increase rotation pool)
GIPHY_API_KEY=
#
# Option C: Gemini free tier (official Google)
# AI_API_KEY=your_google_ai_studio_key
# AI_MODEL=gemini-2.0-flash-lite
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Daily post schedule
TIMEZONE=America/Chicago
DISCUSSION_HOUR=9
MEME_HOUR=12
GROWTH_CHECK_HOUR=18

# Episode source mode:
# - discord: recap when an episode link is posted in DISCORD_EPISODE_CHANNEL_ID
# - rss: poll EPISODE_FEED_URL and recap new episodes
# - youtube: poll YOUTUBE_CHANNEL_URL/videos and recap latest upload
EPISODE_SOURCE_MODE=youtube
EPISODE_FEED_URL=
YOUTUBE_CHANNEL_URL=https://www.youtube.com/@peterdiamandis
EPISODE_POLL_MINUTES=30

# Optional: if DISCORD_INVITE_URL is unset, bot can generate an invite from this channel ID
INVITE_CHANNEL_ID=123456789012345678
