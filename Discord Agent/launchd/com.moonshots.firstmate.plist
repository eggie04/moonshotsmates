<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.moonshots.firstmate</string>

  <key>ProgramArguments</key>
  <array>
    <string>__BOT_DIR__/.venv/bin/python3</string>
    <string>__BOT_DIR__/bot.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__BOT_DIR__</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>__BOT_DIR__/data/bot.log</string>

  <key>StandardErrorPath</key>
  <string>__BOT_DIR__/data/bot.log</string>
</dict>
</plist>
